          "columns": ["client_id"]
        },
        "foreign": []
      },
      "constraints": {
        "unique": [
          {
            "name": "uq_customers_email",
            "columns": ["email_address"]
          }
        ]
      },
      "indexes": [
        {
          "name": "ix_customers_name",
          "columns": ["name"]
        }
      ]
    },
    "product": {
      "name": "items_catalog",
      "columns": [
        {
          "id": "id",
          "name": "id",
          "type": "CHAR(26)"
        },
        {
          "id": "name",
          "name": "name",
          "type": "VARCHAR(1024)"
        },
        {
          "id": "price",
