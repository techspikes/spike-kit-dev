{
  "private": true,
  "name": "@techspikes/spike-kit-dev",
  "version": "1.0.0-draft.2",
  "description": "Specification and tools for agile teams to quickly sketch disposable data stores for user stories.",
  "main": "./lib/index.mjs",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "shot": "./bin/cli.mjs"
  },
  "author": "knzbr <87257088+knzbr@users.noreply.github.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && node scripts/esbuild.ts && dts-bundle-generator --project tsconfig.json --export-referenced-types false --out-file lib/index.d.ts src/index.ts",
    "lint": "eslint . --flag unstable_native_nodejs_ts_config && biome check .",
    "lint:fix": "eslint . --fix --flag unstable_native_nodejs_ts_config && biome check --fix .",
    "test": "tsc --noEmit && c8 --100 node --test  test/**/*.test.ts"
  },
  "files": [
    "bin",
    "docs",
    "lib"
  ],
  "dependencies": {
    "js-yaml": "^4.1.0",
    "oas": "^34.0.2",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@electric-sql/pglite": "^0.5.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.20",
    "@typescript-eslint/parser": "^8.61.0",
    "c8": "^10.1.3",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "kysely": "^0.29.2",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/techspikes/spike-kit-dev.git"
  },
  "bugs": {
    "url": "https://github.com/techspikes/spike-kit-dev/issues"
  },
  "homepage": "https://github.com/techspikes/spike-kit-dev#readme",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  }
}
